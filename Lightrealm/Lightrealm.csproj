<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net6.0</TargetFramework>
    <RollForward>Major</RollForward>
    <PublishReadyToRun>false</PublishReadyToRun>
    <TieredCompilation>false</TieredCompilation>
  </PropertyGroup>
  <PropertyGroup>
    <ApplicationIcon>Icon.ico</ApplicationIcon>
    <ApplicationManifest>app1.manifest</ApplicationManifest>
  </PropertyGroup>
  <ItemGroup>
    <Compile Remove="Content\audio\**" />
    <Compile Remove="Content\character art\**" />
    <Compile Remove="Content\distmap\**" />
    <Compile Remove="Content\tiles\**" />
    <EmbeddedResource Remove="Content\audio\**" />
    <EmbeddedResource Remove="Content\character art\**" />
    <EmbeddedResource Remove="Content\distmap\**" />
    <EmbeddedResource Remove="Content\tiles\**" />
    <None Remove="Content\audio\**" />
    <None Remove="Content\character art\**" />
    <None Remove="Content\distmap\**" />
    <None Remove="Content\tiles\**" />
  </ItemGroup>
  <ItemGroup>
    <None Remove="Content\astrionalis.png" />
    <None Remove="Content\babyshibafont.spritefont" />
    <None Remove="Content\BLKCHCRY.TTF" />
    <None Remove="Content\celestrioris.png" />
    <None Remove="Content\clock.png" />
    <None Remove="Content\droplet.png" />
    <None Remove="Content\gradient.png" />
    <None Remove="Content\gui.png" />
    <None Remove="Content\healthgui.png" />
    <None Remove="Content\Icon.png" />
    <None Remove="Content\inventory gui.png" />
    <None Remove="Content\moon.png" />
    <None Remove="Content\moveguide.png" />
    <None Remove="Content\pixel.png" />
    <None Remove="Content\reaction gui.png" />
    <None Remove="Content\shibafont.spritefont" />
    <None Remove="Content\sky.png" />
    <None Remove="Content\sun.png" />
    <None Remove="Content\title.png" />
    <None Remove="Icon.ico" />
    <None Remove="Icon.bmp" />
  </ItemGroup>
  <ItemGroup>
    <Content Include="Icon.ico" />
  </ItemGroup>
  <ItemGroup>
    <EmbeddedResource Include="Icon.ico" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="MonoGame.Framework.DesktopGL" Version="3.8.1.303" />
    <PackageReference Include="MonoGame.Content.Builder.Task" Version="3.8.1.303" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
    <PackageReference Include="SimplexNoise" Version="2.0.0" />
  </ItemGroup>
  <ItemGroup>
    <None Update="Content\data\last-names.txt">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="Content\data\names.txt">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="Content\data\namesuffixes.txt">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="Content\data\syllables.txt">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="Content\data\words.txt">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="Content\graphics\spritesheet.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>
  <ItemGroup>
    <Folder Include="Content\graphics\" />
  </ItemGroup>
  <Target Name="RestoreDotnetTools" BeforeTargets="Restore">
    <Message Text="Restoring dotnet tools" Importance="High" />
    <Exec Command="dotnet tool restore" />
  </Target>
</Project>